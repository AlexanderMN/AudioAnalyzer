@model AudioAnalyzer.Web.Models.ViewModels.LoginViewModel

<!DOCTYPE html>

<html lang="ru">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход</title>
    <link rel="stylesheet" href="/css/account-style.css">
</head>
<body>
<div id="div-container">
    
    <div id="headline-container">
        Вход
    </div>
    
    <div id="form-container">
        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            Html.AntiForgeryToken();
            <label class="label-container" for="login-input">Логин:</label>
            <div id="login-input">
                @Html.EditorFor(model => model.Username,
                                additionalViewData: new
                                {
                                    htmlAttributes = new
                                    {
                                        @class = "input-field"
                                    }
                                })
                @Html.ValidationMessageFor(model => model.Username)
            </div>

            <label class="label-container" for="password-input">Пароль:</label>
            <div id="password-input">
                @Html.EditorFor(model => model.Password,
                                additionalViewData: new
                                {
                                    htmlAttributes = new
                                    {
                                        @class = "input-field"
                                    }
                                })
                @Html.ValidationMessageFor(model => model.Password)
            </div>
            <button class="form-button" formaction="Account/Register" type="submit" >Регистрация</button>
            <button style="float: right" class="form-button" type="submit">Войти</button>
        }
    </div>
</div>
</body>
</html>