@model AudioAnalyzer.Web.Models.ViewModels.RegisterViewModel

<!DOCTYPE "html">
<html lang="ru">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Регистрация</title>
    <link rel="stylesheet" href="/css/account-style.css">
</head>
<body>
<div id="div-container">
    
    <div id="headline-container">
        Создать аккаунт
    </div>
    <div id="form-container">
        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
        {
            <label class="label-container" for="login-input">Логин:</label>
            <div id="login-input">
                @Html.EditorFor(model => model.Username,
                                additionalViewData: new
                                {
                                    htmlAttributes = new
                                    {
                                        @class = "input-field"
                                    }
                                })
                @Html.ValidationMessageFor(model => model.Username)
            </div>

            <label class="label-container" for="password-input">Пароль:</label>
            <div id="password-input">
                @Html.EditorFor(model => model.Password,
                                additionalViewData: new
                                {
                                    htmlAttributes = new
                                    {
                                        @class = "input-field"
                                    }
                                })
                @Html.ValidationMessageFor(model => model.Password)
            </div>

            <label class="label-container" for="email-input">Почта:</label>
            <div id="email-input">
                @Html.EditorFor(model => model.Email,
                                additionalViewData: new
                                {
                                    htmlAttributes = new
                                    {
                                        @class = "input-field"
                                    }
                                })
                @Html.ValidationMessageFor(model => model.Email)
            </div>

            <button class="form-button" type="submit">Создать</button>
        }
    </div>
</div>
</body>
</html>