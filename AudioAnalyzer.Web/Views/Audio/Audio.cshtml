@model AudioAnalyzer.Web.Models.ViewModels.HomeViewModel;

<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audio analyzer</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/home_onload.js"></script>
    <script src="~/js/signalr/dist/browser/signalr.js"></script>
</head>
<body>
<div class="container">
    <div id="header">Header</div>
    <div id="body">
        <div id="sidebar">
            <div id="user-account-div">
                <div>
                    Профиль
                </div>
                <div id="user-img-name-container">
                    <img id="user-account-picture"
                         width="50" height="50"
                         src="/img/DefaultUserImg.webp"
                         alt="user img"/>
                    <label id="user-name-label" for="user-account-picture">
                        @Model.UserName
                    </label>
                </div>
            </div>
            <table id="options-table">
                <tr>
                    <td>
                        <button id="button-input" class="options-button">
                            Загрузить аудиофайл
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <button id="button-spectrogram" class="options-button">
                            Спектрограмма аудиофайла
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <button id="button-basicinfo" class="options-button">
                            Базовая информация о аудиофайле
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <button id="button-transcribe" class="options-button">
                            Транскрибация аудиофайла
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <button id="button-summary" class="options-button">
                            Краткое содержание аудиофайла
                        </button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <button id="button-search" class="options-button">
                            Поиск по аудиофайлу
                        </button>
                    </td>
                </tr>
            </table>
            <script src="/js/sidebar.js"></script>
        </div>
        <div id="main">
            
        </div>
    </div>
    <div id="footer">
        <div class="audio-player">
            <audio id="audio" controls>
                
            </audio>
        </div>
    </div>
</div>
</body>
</html>
